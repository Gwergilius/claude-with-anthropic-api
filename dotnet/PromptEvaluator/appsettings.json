{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "System": "Warning",
      "Microsoft": "Warning"
    }
  },
  "Anthropic": {
    "Model": "claude-sonnet-4-5",
    "MaxTokens": 1000,
    "Temperature": 1.0
  },
  "Evaluator": {
    "DatasetFile": "Data/dataset.json",
    "PromptFile": "Data/prompt.yaml",
    "JsonOutputFile": "Data/output.json",
    "HtmlOutputFile": "Data/output.html",
    "MaxConcurrentTasks": 3
  }
}
