@page "/"

<PageTitle>Claude Chat</PageTitle>

<div class="home-chat-layout">
    <div class="home-chat-layout__main">
        <ConfigurationAccordion @key="_configPanelKey" />

        <div class="chat-wrapper">
            <ChatHistory
                Messages="AnthropicClient.Context"
                IsAwaitingHttp="_isAwaitingHttp"
                StreamPending="_isReadingStream"
                OnStopStreaming="HandleStopStreaming" />

            <ChatInput IsDisabled="IsChatBusy" OnSend="HandleSend" />
        </div>

        <RequestLogAccordion />
    </div>

    <div class="status-bar">
        <span class="status-bar__left @(!string.IsNullOrEmpty(errorMessage) ? "status-bar__left--error" : "")">
            @errorMessage
        </span>
        <span class="status-bar__right">
            @OptionsMonitor.CurrentValue.Model &nbsp;·&nbsp; T=@OptionsMonitor.CurrentValue.Temperature.ToString("0.##")
        </span>
    </div>
</div>
