@page "/"

<PageTitle>Claude Chat</PageTitle>

<div class="chat-wrapper">
    <ChatHistory Messages="AnthropicClient.Context" IsLoading="isLoading" />

    <ChatInput IsDisabled="isLoading" OnSend="HandleSend" />

    <div class="status-bar">
        <span class="status-bar__left @(!string.IsNullOrEmpty(errorMessage) ? "status-bar__left--error" : "")">
            @errorMessage
        </span>
        <span class="status-bar__right">
            @Options.Value.Model &nbsp;·&nbsp; T=@Options.Value.Temperature
        </span>
    </div>
</div>
